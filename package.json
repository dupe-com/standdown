{
  "name": "standdown",
  "version": "0.3.1",
  "description": "Affiliate stand-down, done right, for browser extensions.",
  "author": "Dupe (https://dupe.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dupe-com/standdown.git"
  },
  "homepage": "https://github.com/dupe-com/standdown#readme",
  "bugs": "https://github.com/dupe-com/standdown/issues",
  "keywords": [
    "affiliate",
    "stand-down",
    "standdown",
    "browser-extension",
    "compliance",
    "attribution",
    "mv3",
    "affiliate-marketing",
    "cookie-stuffing"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "POLICIES.md",
    "ADOPTING.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./policies": {
      "types": "./dist/policies.d.ts",
      "import": "./dist/policies.mjs",
      "require": "./dist/policies.cjs"
    },
    "./webext": {
      "types": "./dist/webext.d.ts",
      "import": "./dist/webext.mjs",
      "require": "./dist/webext.cjs"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "import": "./dist/content.mjs",
      "require": "./dist/content.cjs"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.mjs",
      "require": "./dist/url.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "build": "tsup",
    "test": "vitest run",
    "policies-cite-check": "node scripts/policies-cite-check.mjs",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^24.0.14",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
